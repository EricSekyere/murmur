# Rust
/target/
**/*.rs.bk
# Cargo.lock IS committed: this is an application, and a committed lock
# gives reproducible CI builds (without it, CI resolves fresh deps and can
# pick up a newly published, broken transitive crate).

# Models (downloaded at runtime)
/models/*.bin
/models/*.ggml
/models/*.onnx

# Resources (downloaded at build/runtime)
/resources/silero_vad.onnx

# Claude Code
.claude/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.local

# Tauri
/crates/murmur-app/gen/

# Tauri updater private signing key — NEVER commit
crates/murmur-app/.tauri-signing-key.key

UPDATER_SETUP.local.md
crates/murmur-app/.tauri-signing-key.key.pub

# CI-generated Windows signing config fragment (Trusted Signing)
crates/murmur-app/.winsign.conf.json
