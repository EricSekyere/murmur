{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Murmur",
  "version": "0.4.0",
  "identifier": "com.murmur.app",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Murmur",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 540,
        "resizable": true,
        "visible": true,
        "focus": false
      },
      {
        "label": "widget",
        "title": "",
        "url": "widget.html",
        "width": 176,
        "height": 50,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": true,
        "x": 20,
        "y": 20
      },
      {
        "label": "caption",
        "title": "",
        "url": "caption.html",
        "width": 380,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "x": 0,
        "y": 0
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "tooltip": "Murmur - Voice to Text"
    },
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libasound2"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/EricSekyere/murmur/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5RDU5RTFCQkIwNEUwMApSV1FBVHJDNzRWbWREOTB6YjBxQ0RWLzAycmJ1V09CbFZkZnhTdjRkLzJ3bFFXeXYwQ2MzNUZ2eQo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
